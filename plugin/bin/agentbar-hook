#!/usr/bin/env bash
#
# agentbar-hook — bridge between Claude Code hooks and the AgentBar menu bar app.
#
# Usage: agentbar-hook <event> [agent]
#        agentbar-hook --selftest
#   events: working | ask | permission | elicit | resolved | notify | stop | subagent | sessionend | stopfailure
#   agent:  claude (default) | copilot  — which coding agent fired the event. The Claude
#           Code plugin omits it; the Copilot CLI hook config passes "copilot". It is sent
#           to AgentBar in the X-AgentBar-Agent header so the app can tag and route the row.
#
# AgentBar is notify-only: every event is fire-and-forget. This script reads the
# hook payload from stdin, POSTs it to AgentBar's local HTTP server so it can post
# a notification, and returns immediately with no output — the session never blocks
# on AgentBar, and the prompt is answered in the terminal as usual.
#
# Fail-open contract: if AgentBar is not installed, not running and cannot be
# launched, times out, or errors in any way, this script exits 0 with no
# output so the prompt falls back to the normal terminal experience.
#
# `--selftest` breaks the silent contract on purpose: it prints a human-readable
# diagnosis of each moving part (curl, server.json, the live server) and exits
# non-zero if anything is wrong, so "why aren't my notifications showing?" is answerable.

set -u

EVENT="${1:-notify}"
AGENT="${2:-claude}"
STATE_DIR="${HOME}/Library/Application Support/AgentBar"
SERVER_FILE="${STATE_DIR}/server.json"
BUNDLE_ID="com.jreed91.AgentBar"

PORT=""
TOKEN=""

have_curl() {
  command -v curl >/dev/null 2>&1
}

read_server_file() {
  [ -f "$SERVER_FILE" ] || return 1
  # server.json is written by AgentBar as: {"port":12345,"pid":678,"version":"x","token":"hex"}
  PORT="$(sed -n 's/.*"port"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$SERVER_FILE")"
  TOKEN="$(sed -n 's/.*"token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$SERVER_FILE")"
  [ -n "$PORT" ] && [ -n "$TOKEN" ]
}

server_alive() {
  [ -n "$PORT" ] || return 1
  have_curl || return 1
  curl -sf -m 2 -H "Authorization: Bearer ${TOKEN}" \
    "http://127.0.0.1:${PORT}/v1/health" >/dev/null 2>&1
}

launch_app() {
  open -g -b "$BUNDLE_ID" 2>/dev/null || open -g -a "AgentBar" 2>/dev/null
}

# --selftest: diagnose the pipeline and exit. Never reads stdin.
if [ "$EVENT" = "--selftest" ] || [ "$EVENT" = "selftest" ]; then
  status=0

  if have_curl; then
    echo "ok   curl found: $(command -v curl)"
  else
    echo "FAIL curl not found on PATH — the hook cannot reach AgentBar"
    status=1
  fi

  if [ -f "$SERVER_FILE" ]; then
    if read_server_file; then
      echo "ok   server.json readable (port ${PORT})"
    else
      echo "FAIL server.json present but missing port/token: ${SERVER_FILE}"
      status=1
    fi
  else
    echo "warn server.json not found — AgentBar has not run yet (${SERVER_FILE})"
  fi

  if server_alive; then
    version="$(curl -sf -m 2 -H "Authorization: Bearer ${TOKEN}" \
      "http://127.0.0.1:${PORT}/v1/health" 2>/dev/null)"
    echo "ok   server responding on 127.0.0.1:${PORT} — ${version}"
  else
    echo "warn server not responding; attempting to launch AgentBar…"
    if launch_app; then
      i=0
      while [ "$i" -lt 25 ]; do
        sleep 0.2
        if read_server_file && server_alive; then break; fi
        i=$((i + 1))
      done
      if server_alive; then
        echo "ok   AgentBar launched and responding on 127.0.0.1:${PORT}"
      else
        echo "FAIL AgentBar did not come up — is the app installed in /Applications?"
        status=1
      fi
    else
      echo "FAIL could not launch AgentBar (bundle id ${BUNDLE_ID}) — install the Homebrew cask"
      status=1
    fi
  fi

  [ "$status" -eq 0 ] && echo "AgentBar hook: all good." || echo "AgentBar hook: problems found (see above)."
  exit "$status"
fi

# Normal fire-and-forget path. Without curl there is nothing we can do — fail open.
have_curl || exit 0

# Consume the payload first so we never leave Claude Code blocked on a full pipe.
PAYLOAD="$(cat)"

read_server_file || true
if ! server_alive; then
  # Never delete server.json from here: a health check can time out against a live
  # but momentarily busy app, and `open` won't relaunch a running app to republish
  # the file — deleting it would kill notifications until the app restarts. A truly
  # stale file just keeps failing server_alive until the relaunched app overwrites it.
  PORT=""; TOKEN=""
  launch_app || exit 0
  # Wait for the app to boot and publish server.json, but stay under the 10s hook
  # timeout Claude Code enforces (each probe can burn up to 2s on a hung port).
  while [ "$SECONDS" -lt 8 ]; do
    sleep 0.2
    if read_server_file && server_alive; then break; fi
  done
  server_alive || exit 0
fi

# Best-effort clues for "Focus terminal", in order of reliability. TERM_PROGRAM and
# TERMINAL_EMULATOR are set by the actual terminal that spawned this shell (so a JetBrains
# IDE reports TERMINAL_EMULATOR=JetBrains-JediTerm); __CFBundleIdentifier reflects whatever
# *launched* the app and can be stale (e.g. iTerm's id when an IDE was started from a
# shell), so the app treats it as a last resort.
# Strip CR/LF so an environment-controlled value can never smuggle extra headers
# into the request (curl passes -H content through verbatim).
HOST_TERM="$(printf '%s' "${TERM_PROGRAM:-}" | tr -d '\r\n')"
HOST_TERMEMU="$(printf '%s' "${TERMINAL_EMULATOR:-}" | tr -d '\r\n')"
HOST_BUNDLE="$(printf '%s' "${__CFBundleIdentifier:-}" | tr -d '\r\n')"

# Fire-and-forget: the server acknowledges immediately (no body), so a short
# timeout is plenty. We ignore the response — the prompt is answered in the terminal.
# The payload goes to curl via stdin, not argv: a large PostToolUse tool_response
# can exceed ARG_MAX, and an exec failure there would silently drop the event.
printf '%s' "$PAYLOAD" | curl -sf -m 5 -X POST \
  -H "Authorization: Bearer ${TOKEN}" \
  -H "Content-Type: application/json" \
  -H "X-AgentBar-Term: ${HOST_TERM}" \
  -H "X-AgentBar-TermEmu: ${HOST_TERMEMU}" \
  -H "X-AgentBar-Host: ${HOST_BUNDLE}" \
  -H "X-AgentBar-Agent: ${AGENT}" \
  --data-binary @- \
  "http://127.0.0.1:${PORT}/v1/${EVENT}" >/dev/null 2>&1 || exit 0

exit 0
