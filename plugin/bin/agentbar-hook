#!/usr/bin/env bash
#
# agentbar-hook — bridge between Claude Code hooks and the AgentBar menu bar app.
#
# Usage: agentbar-hook <event>
#   events: working | ask | permission | elicit | resolved | notify | stop | subagent | sessionend | stopfailure
#
# AgentBar is notify-only: every event is fire-and-forget. This script reads the
# hook payload from stdin, POSTs it to AgentBar's local HTTP server so it can post
# a notification, and returns immediately with no output — the session never blocks
# on AgentBar, and the prompt is answered in the terminal as usual.
#
# Fail-open contract: if AgentBar is not installed, not running and cannot be
# launched, times out, or errors in any way, this script exits 0 with no
# output so the prompt falls back to the normal terminal experience.

set -u

EVENT="${1:-notify}"
STATE_DIR="${HOME}/Library/Application Support/AgentBar"
SERVER_FILE="${STATE_DIR}/server.json"
BUNDLE_ID="com.jreed91.AgentBar"

PORT=""
TOKEN=""

read_server_file() {
  [ -f "$SERVER_FILE" ] || return 1
  # server.json is written by AgentBar as: {"port":12345,"token":"hex"}
  PORT="$(sed -n 's/.*"port"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$SERVER_FILE")"
  TOKEN="$(sed -n 's/.*"token"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$SERVER_FILE")"
  [ -n "$PORT" ] && [ -n "$TOKEN" ]
}

server_alive() {
  [ -n "$PORT" ] || return 1
  curl -sf -m 2 -H "Authorization: Bearer ${TOKEN}" \
    "http://127.0.0.1:${PORT}/v1/health" >/dev/null 2>&1
}

launch_app() {
  open -g -b "$BUNDLE_ID" 2>/dev/null || open -g -a "AgentBar" 2>/dev/null
}

# Consume the payload first so we never leave Claude Code blocked on a full pipe.
PAYLOAD="$(cat)"

read_server_file || true
if ! server_alive; then
  launch_app || exit 0
  # Wait up to ~5s for the app to boot and publish server.json.
  i=0
  while [ "$i" -lt 25 ]; do
    sleep 0.2
    if read_server_file && server_alive; then break; fi
    i=$((i + 1))
  done
  server_alive || exit 0
fi

# Best-effort clues for "Focus terminal", in order of reliability. TERM_PROGRAM and
# TERMINAL_EMULATOR are set by the actual terminal that spawned this shell (so a JetBrains
# IDE reports TERMINAL_EMULATOR=JetBrains-JediTerm); __CFBundleIdentifier reflects whatever
# *launched* the app and can be stale (e.g. iTerm's id when an IDE was started from a
# shell), so the app treats it as a last resort.
HOST_TERM="${TERM_PROGRAM:-}"
HOST_TERMEMU="${TERMINAL_EMULATOR:-}"
HOST_BUNDLE="${__CFBundleIdentifier:-}"

# Fire-and-forget: the server acknowledges immediately (no body), so a short
# timeout is plenty. We ignore the response — the prompt is answered in the terminal.
curl -sf -m 5 -X POST \
  -H "Authorization: Bearer ${TOKEN}" \
  -H "Content-Type: application/json" \
  -H "X-AgentBar-Term: ${HOST_TERM}" \
  -H "X-AgentBar-TermEmu: ${HOST_TERMEMU}" \
  -H "X-AgentBar-Host: ${HOST_BUNDLE}" \
  --data-binary "$PAYLOAD" \
  "http://127.0.0.1:${PORT}/v1/${EVENT}" >/dev/null 2>&1 || exit 0

exit 0
