{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      { "type": "command", "bash": "__AGENTBAR_HOOK__ working copilot", "timeoutSec": 10 }
    ],
    "postToolUse": [
      { "type": "command", "bash": "__AGENTBAR_HOOK__ resolved copilot", "timeoutSec": 10 }
    ],
    "sessionEnd": [
      { "type": "command", "bash": "__AGENTBAR_HOOK__ sessionend copilot", "timeoutSec": 10 }
    ],
    "errorOccurred": [
      { "type": "command", "bash": "__AGENTBAR_HOOK__ stopfailure copilot", "timeoutSec": 10 }
    ]
  }
}
